<!DOCTYPE html>
<!-- Autogenerated with Rez v<%= Rez.version() %> -->
<!-- Modifications will be overwritten -->
<% alias Rez.AST.Asset %>
<% alias Rez.AST.NodeHelper %>
<html class="<%= NodeHelper.get_attr_value(@game, "html_classes", "") %>">
  <head>
    <meta charset="UTF-8">
    <meta name="author" content="<%= NodeHelper.get_attr_value(@game, "author_name") %>">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= NodeHelper.get_attr_value(@game, "title") %></title>
    <%= for {:string, url} <- NodeHelper.get_attr_value(@game, "links", []) do %>
      <link rel="stylesheet" href="<%= url %>">
    <% end %>
    <%= for js_asset <- @js_pre_runtime_assets do %>
      <%= Asset.asset_tag(js_asset) %>
    <% end %>
    <script src="assets/js/runtime.js"></script>
    <%= for js_asset <- @js_post_runtime_assets do %>
      <%= Asset.asset_tag(js_asset) %>
    <% end %>
    <%= for style_asset <- @style_assets do %>
      <%= Asset.asset_tag(style_asset) %>
    <% end %>
    <style type="text/css">
      /* Rez default styles */
      @keyframes rez-modal-bg-in    { from {opacity:0}                              to {opacity:1} }
      @keyframes rez-modal-scale-in { from {opacity:0; transform:scale(.95)}        to {opacity:1; transform:scale(1)} }
      @keyframes rez-modal-fade-in  { from {opacity:0}                              to {opacity:1} }
      @keyframes rez-modal-slide-in { from {opacity:0; transform:translateY(20px)}  to {opacity:1; transform:translateY(0)} }

      .modal[class*="rez-anim-"] .modal-background { animation: rez-modal-bg-in    var(--rez-modal-dur,180ms) ease-out; }
      .rez-anim-scale .modal-card                  { animation: rez-modal-scale-in var(--rez-modal-dur,180ms) ease-out; }
      .rez-anim-fade  .modal-card                  { animation: rez-modal-fade-in  var(--rez-modal-dur,180ms) ease-out; }
      .rez-anim-slide .modal-card                  { animation: rez-modal-slide-in var(--rez-modal-dur,180ms) ease-out; }

      @media (prefers-reduced-motion: reduce) {
        .modal .modal-card, .modal .modal-background { animation: none !important; }
      }

      /* Custom game styles */
      <%= for style <- @styles do %>
        <%= style.styles %>
      <% end %>
    </style>
  </head>
  <body class="<%= NodeHelper.get_attr_value(@game, "body_classes", "") %>">
    <div id="game-container">
      <!-- Game output will be inserted here -->
    </div>
    <%= for {:string, url} <- NodeHelper.get_attr_value(@game, "scripts", []) do %>
      <script src="<%= url %>"></script>
    <% end %>
    <%= for js_asset <- @js_body_runtime_assets do %>
      <%= Asset.asset_tag(js_asset) %>
    <% end %>
    <script type="text/javascript">
      // Custom game scripts
      <%= for script <- @scripts do %>
        <%= script.script %>
      <% end %>
    </script>
  </body>
  <script>
    Rez.loadMods().then(function() {
      $game.start("game-container");
    });
  </script>
  <script>
  <%= for {:list_binding, {js_event_name, {:literal, {:string, rez_event_name}}}} <- NodeHelper.get_attr_value(@game, "start_events", %{}) do %>
    document.addEventListener('<%= js_event_name %>', () => {
      $game.eventProcessor.handleCustomEvent("<%= rez_event_name %>", {});
    });
  <% end %>
  </script>
</html>
